@model StudentMVC.Models.Student

<div class="container mt-4">
    <h2>Chi tiết sinh viên</h2>
    <hr />

    <div class="row">
        <div class="col-md-4">
            <img src="@Model.ImgUrl" style="width:200px" class="img-thumbnail" />
        </div>

        <div class="col-md-8">
            <p><b>Mã số:</b> @Model.Id</p>
            <p><b>Họ tên:</b> @Model.Name</p>
            <p><b>Tuổi:</b> @Model.Age</p>
            <p><b>Giới tính:</b> @(Model.Gender ? "Nam" : "Nữ")</p>
            <p><b>Mô tả:</b> @Model.Des</p>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="ListStudents" class="btn btn-secondary">Quay lại</a>
    </div>
</div>