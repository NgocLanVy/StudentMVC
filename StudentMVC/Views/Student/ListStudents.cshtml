@model List<StudentMVC.Models.Student>

<div class="container mt-4">
    <h1 class="fw-bold">Thông tin sinh viên lớp K21</h1>

    <table class="table table-bordered align-middle text-center">
        <thead class="table-light">
            <tr>
                <th>STT</th>
                <th>Tên</th>
                <th>Tuổi</th>
                <th>Giới tính</th>
                <th>Hình ảnh</th>
                <th>Chi tiết</th>
                <th>Chỉnh sửa</th>
                <th>Xóa</th>
            </tr>
        </thead>
        <tbody>
            @{
                int stt = 1;
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@stt</td>
                    <td class="text-start">@item.Name</td>
                    <td>@item.Age</td>
                    <td>@(item.Gender ? "Nam" : "Nữ")</td>
                    <td>
                        <img src="@item.ImgUrl" alt="avatar" style="width: 80px;" />
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id">Detail</a>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    </td>
                    <td>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="text-primary">Delete</a>
                    </td>
                </tr>
                stt++;
            }
        </tbody>
    </table>

    <a asp-action="AddStudent" class="btn btn-link p-0">Add</a>
</div>